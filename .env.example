# Required
# Anthropic API key used to call Claude Haiku 4.5
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Port the Express server listens on (Railway sets this automatically at deploy time)
PORT=3000

# Optional — override the Shopify Storefront MCP endpoint (defaults to
# https://b4txwx-6t.myshopify.com/api/mcp in code if not set)
# SHOPIFY_MCP_ENDPOINT=https://b4txwx-6t.myshopify.com/api/mcp
